# Deployment docs with secrets
TOKEN_DEPLOYMENT.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Bases SQLite locales (stray/dev copies — la vraie base vit sous state/,
