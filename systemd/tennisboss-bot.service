[Unit]
Description=TennisBoss Bot API (Flask, port 8000 — backend Android)
After=network.target tennisboss-quant.service

[Service]
Type=simple
User=alchemist
WorkingDirectory=/mnt/c/Users/donpa/TennisBoss
EnvironmentFile=/mnt/c/Users/donpa/TennisBoss/.env
ExecStart=/usr/bin/python3 run.py serve --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5s

StandardOutput=journal
StandardError=journal
SyslogIdentifier=tennisboss-bot

[Install]
WantedBy=multi-user.target
