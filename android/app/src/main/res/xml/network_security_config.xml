<?xml version="1.0" encoding="utf-8"?>
<!-- Release : HTTPS uniquement, aucune exception cleartext. Les exceptions de dev
     (localhost/émulateur/IP LAN) vivent dans app/src/debug/res/xml/ (ne partent pas
     dans l'APK publié). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
