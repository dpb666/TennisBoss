# TennisBoss — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer le fichier .env.

# Sportradar (données tennis)
SR_KEY=your_sportradar_key

# odds-api.io (cotes, lecture seule)
ODDS_API_KEY=your_odds_api_key
# Line shopping : books à comparer (on parie le meilleur prix). Plus de books
# mous = plus de chances de battre la clôture. Noms exacts : /v3/bookmakers.
ODDS_BOOKMAKERS=Bet365,Betfair Exchange
# Book "sharp" servant de proba juste no-vig (exchange = quasi sans marge).
ODDS_SHARP_BOOK=Betfair Exchange

# API-Tennis (fixtures / live scores)
AT_API_KEY=your_api_tennis_key

# OddsPapi (oddspapi.io) — fixtures ATP/WTA/Challenger/ITF, free tier 250
# req/mois SANS carte bancaire. Plusieurs comptes = plusieurs clés (pool
# rotatif, même principe qu'ODDS_API_KEY ci-dessus) : ODDSPAPI_KEY_2..12.
# Pas encore câblé dans /api/upcoming — voir bot/oddspapi_feeder.py.
ODDSPAPI_KEY=your_oddspapi_key

# Stake (plateforme de paris)
STAKE_KEY=your_stake_key

# Chat IA — Groq primaire -> Gemini/Gemma cloud -> Ollama local
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemma-4-31b-it
# Alternative Gemini/Gemma moins grosse : gemma-4-26b-a4b-it
# GEMINI_THINKING_LEVEL=high
OLLAMA_FALLBACK_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL=gemma3:4b

# Cloudflare — Worker proxy (workers.dev) + Tunnel privé (cfargotunnel.com)
# Créer un token API sur : dash.cloudflare.com/profile/api-tokens
#   Permissions : Workers Scripts Edit + Cloudflare Tunnel Edit + Account Read
# Puis lancer : bash cloudflare/setup.sh
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# Token du tunnel (généré par setup.sh ou Cloudflare Dashboard)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=your_telegram_user_id
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.dev

# Optionnel
SLACK_WEBHOOK_URL=
BANKROLL=1000
SETTLEMENT_INTERVAL_S=300
CHAT_API_URL=http://127.0.0.1:8001
TENNISBOSS_API_TOKEN=

# --- Plans d'authentification (docs/ARCHITECTURE_BLUEPRINT.md §11, Q3 #3) ---
# TENNISBOSS_ENV=prod active le default-deny : l'API REFUSE de démarrer sans
# TENNISBOSS_API_TOKEN (en dev : simple avertissement si exposée au LAN).
TENNISBOSS_ENV=dev
# Token admin optionnel : s'il est défini, les routes d'écriture (settlement,
# learn, ingest, backfill, inplay picks POST/PUT/DELETE) exigent l'en-tête
# X-Admin-Token en PLUS de X-API-Token. Absent = comportement historique.
TENNISBOSS_ADMIN_TOKEN=
